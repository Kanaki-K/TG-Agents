# =========================================================
#  ОБРАЗЕЦ переменных окружения. Скопируй в файл .env и заполни значения.
#  .env в git НЕ попадает (см. .gitignore). Этот файл (.env.example) — попадает.
# =========================================================

# GitHub Personal Access Token (fine-grained): репо TG-Agents, Contents: Read and write
GITHUB_TOKEN=

# Боты команды: у КАЖДОГО агента свой бот в @BotFather → своя переменная *_BOT_TOKEN.
# Секретарь / Личный ассистент (@SecAI_Bot):
SECRETARY_BOT_TOKEN=
# Аналитик канала (оценка контента по метрикам; запуск: python run_analyst.py):
ANALYST_BOT_TOKEN=
# Разработчик (улучшает других агентов; запуск: python run_dev.py):
DEVELOPER_BOT_TOKEN=
# Скаут (разведка трендов/источников; запуск: python run_scout.py):
SCOUT_BOT_TOKEN=
# Криейтор (пишет посты по направлению; запуск: python run_creator.py):
CREATOR_BOT_TOKEN=
# (Публикация вшита в Криейтора командой /schedule — отдельного бота-Публикатора нет.)
# (будущие агенты добавят свои: ADAPTER_BOT_TOKEN= ...)

# Необязательный отдельный бот для разового сбора id кастом-эмодзи
# (connectors.telegram_emoji.collect_ids). Если пусто — сборщик берёт CREATOR_BOT_TOKEN
# (тогда на время сбора останови криейтора). Свой токен = собирать, не останавливая криейтора.
EMOJI_BOT_TOKEN=

# API-ключ Anthropic (общий, для агентов без своего ключа)
ANTHROPIC_API_KEY=
# Отдельный ключ Claude для аналитика (необязательно; для автономной работы и учёта расходов)
ANALYST_ANTHROPIC_KEY=
# Отдельный ключ Claude для Разработчика (необязательно; он на Opus — удобно считать расходы отдельно)
DEVELOPER_ANTHROPIC_KEY=
# Отдельный ключ Claude для Скаута (необязательно; своя разведка и учёт расходов)
SCOUT_ANTHROPIC_KEY=
# Отдельный ключ Claude для Криейтора (необязательно; он на Opus — письмо флагманов)
CREATOR_ANTHROPIC_KEY=

# --- Telegram Client API (MTProto) — сбор истории канала (агент «Админ канала») ---
# api_id и api_hash берутся на my.telegram.org/apps (разово)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_CHANNEL=KANAKI CRYPTO
# TELEGRAM_2FA=   # только если на аккаунте включён облачный пароль (2FA)
# Готовая строка сессии (из make_session.py, запущенного у владельца). Если задана — вход не нужен.
TELEGRAM_SESSION=

# --- Публикатор — нативная публикация в канал через MTProto (тот же аккаунт-публикатор) ---
# Публикуем userbot'ом (аккаунт @Amanbabai228, сессия выше TELEGRAM_SESSION), а не Bot API:
# у userbot нет лимитов Bot API, пост ложится как руками (обложка сверху + полный текст).
# Куда постить: @username канала, t.me-ссылка или числовой id. На обкатке — ТЕСТ-канал, не основной;
# аккаунт-публикатор должен быть в нём админом с правом постить.
PUBLISH_CHANNEL=
# Есть ли Premium у аккаунта-публикатора (поднимает лимит подписи к фото 1024→2048). 1/да = есть.
# На длинные посты (флагман 2800–4096) не влияет — те идут обложкой-превью над текстом.
PUBLISH_PREMIUM=
# Как слать ДЛИННЫЙ пост с обложкой: preview (по умолч.) — обложка крупным превью над текстом,
# одним сообщением (вид 17.png); split — фото и текст двумя сообщениями (гарантированно, без хостинга).
PUBLISH_LONG_MODE=
# Часовой пояс контент-плана. ЛУЧШЕ задать ИМЕНЕМ (учитывает переход на летнее/зимнее время сам):
# Europe/Berlin (Франкфурт), Europe/Kyiv, Europe/Moscow и т.п. Нужен пакет tzdata (в requirements).
PUBLISH_TZ=Europe/Berlin
# Запасной вариант, если PUBLISH_TZ пуст/недоступен — фиксированное смещение от UTC (по умолч. +3, без DST).
PUBLISH_UTC_OFFSET=
# Точное время в окне (пост-стандарт даёт окно, не точку). Флагман — окно 16–19:00, короткий 14–19:00.
PUBLISH_FLAGSHIP_TIME=17:00
PUBLISH_SHORT_TIME=15:00
# Мейн владельца — куда аккаунт-публикатор шлёт «запланировано на …» (@username / ссылка / id).
PUBLISH_NOTIFY=

# --- X (Twitter) — разведка лидеров мнений Скаутом (эдж над дип-ресёрчем) ---
# Доступ read-only через сессию РАСХОДНОГО (бёрнер) аккаунта, НЕ личного (риск бана).
# Cookies из браузера, где залогинен бёрнер: DevTools (F12) → Application/Хранилище →
# Cookies → https://x.com → значения auth_token и ct0. Проверка: python -m connectors.x_scan.login
X_AUTH_TOKEN=
X_CT0=

# --- ChatGPT (картинки флагмана) — рендер с РАСХОДНОГО (бёрнер) аккаунта через веб ---
# Платный API не используем: берём бесплатный рендер с бёрнера ChatGPT. Секрета тут нет —
# сессия хранится в профиле браузера data/gpt_profile/ (вне git). Вход разовый, руками:
#   python -m connectors.gpt_image.login
# По умолчанию браузер видимый (нужно для входа). Чтобы рендерить в фоне — поставь 1.
# Если Cloudflare начнёт резать скрытый режим — убери обратно (пусто).
GPT_IMAGE_HEADLESS=
# Какой браузер гонять: chrome (по умолчанию — настоящий установленный Chrome, честный
# отпечаток, проверка «вы человек» на входе проходит надёжнее) | msedge | chromium (bundled).
# Если Chrome не установлен — коннектор сам откатится на bundled Chromium.
GPT_IMAGE_BROWSER_CHANNEL=
# ТЕСТОВЫЙ режим картинок: не дёргать ChatGPT, отдавать УЖЕ готовую (бережём дневной лимит,
# когда тестируем доставку поста+обложки). 1 = взять самую свежую PNG из data/gpt_images/;
# либо укажи путь к конкретной картинке. Пусто = обычная генерация через бёрнер.
GPT_IMAGE_STUB=

# --- Секреты (НИКОГДА не коммитим) ---
.env
.env.*
!.env.example
*.key
*.pem
secrets/

# --- Telegram ---
*.session
*.session-journal

# --- Память: бэкапим отдельно, но сами файлы памяти версионируем.
#     Сырые/большие выгрузки — НЕ в git ---
data/
exports/

# --- Python ---
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# --- Локальные настройки Claude Code (не делим через git) ---
.claude/settings.local.json

# --- Мастерская Разработчика: предложения и локальные бэкапы версий агентов ---
#     (промежуточные файлы; версионная история целиком — в самом git) ---
agents/*/SKILL.proposed.md
agents/*/.history/

# --- Скаут: очереди предложенного (транзиентные, владелец разбирает) ---
memory/sources.pending.md
memory/x_leaders.pending.md

# --- Скаут: полные брифы разведки (рабочий материал Криейтора, регенерируются каждый /scan) ---
memory/briefs/

# --- Криейтор: архив драфтов постов (рабочий выход, владелец правит и публикует) ---
memory/drafts/

# --- Скаут: леджер авторов X (живое состояние курации, ведётся автоматически) ---
memory/x_authors.json

# --- Контекст разговоров с Claude между сессиями (локально, не делим через git) ---
notes/

# --- IDE / прочее ---
.idea/
.vscode/
.DS_Store
*.log
